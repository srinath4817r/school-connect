PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/school_connect?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secret_jwt_access_token_secret_key_12345
JWT_REFRESH_SECRET=your_super_secret_jwt_refresh_token_secret_key_12345
JWT_EXPIRE=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Firebase Service Account JSON Path
FIREBASE_SERVICE_ACCOUNT_PATH=./config/firebase-service-account.json

# Nodemailer / Gmail SMTP
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password

# Rate Limiter
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
